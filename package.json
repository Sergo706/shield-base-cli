{
  "name": "@riavzon/shield-base",
  "version": "1.1.1",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "author": "Sergio contact@riavzon.com",
  "license": "MIT",
  "description": "Shield-Base is a command-line tool designed to aggregate, process, and compile network intelligence data into offline ready formats. It fetches data from multiple public sources, including BGP routing tables, geographic location databases, and threat intelligence lists, and consolidates them for use in security analysis and traffic filtering.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sergo706/shield-base-cli.git"
  },
  "homepage": "https://github.com/Sergo706/shield-base#readme",
  "bugs": {
    "url": "https://github.com/Sergo706/shield-base-cli/issues"
  },
  "keywords": [
    "geoip",
    "geo data",
    "city data",
    "geolocation",
    "tor exist nodes",
    "mmdb",
    "threat-intelligence",
    "mmdb",
    "firehol",
    "bgp",
    "asn",
    "botnet",
    "security",
    "cli"
  ],
  "bin": {
    "shield-base": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    },
    "./main": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "extract-zip": "^2.0.1",
    "ipaddr.js": "^2.3.0",
    "magic-regexp": "^0.11.0",
    "lint": "eslint .",
    "tar": "^7.5.10"
  },
  "devDependencies": {
    "@types/extract-zip": "^2.0.0",
    "@types/node": "^25.3.5",
    "@types/tar": "^6.1.13",
    "citty": "^0.2.1",
    "eslint": "^9.39.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}